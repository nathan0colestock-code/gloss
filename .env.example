# Foxed env — copy to .env and fill in.
# Loaded by server.js at startup (simple KEY=VALUE parser, no `export`, no interpolation).

# Gemini API key. Required — without it, parse/reexamine/voice/chat all fail.
# Get one at https://aistudio.google.com/apikey.
GEMINI_API_KEY=

# HTTP port. Optional — defaults to 3747. The UI hard-codes no port; it's same-origin.
PORT=3747

# Google OAuth client JSON path. Optional — only needed if you want the Docs/Drive
# fetch on artifacts / references to work. Download the OAuth client JSON from
# Google Cloud Console (Desktop app credential type) and point this at it.
# If unset, google.js falls back to DEFAULT_CLIENT_JSON (see google.js:21).
# GOOGLE_OAUTH_CLIENT_JSON=/absolute/path/to/client_secret.json

# Google Drive auto-capture poll interval in milliseconds. Optional — defaults to
# 10 minutes (600000). Lower for faster detection; raise to reduce API calls.
# GOOGLE_DRIVE_POLL_INTERVAL_MS=600000

# Enable verbose debug logging (drive-poll, PDF progress, glossary, audit).
# Optional — omit or set to anything other than '1' to keep logs quiet.
# DEBUG=1
