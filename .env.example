# Foxed env — copy to .env and fill in.
# Loaded by server.js at startup (simple KEY=VALUE parser, no `export`, no interpolation).

# ── Auth ─────────────────────────────────────────────────────────────────────
# Required in production. Generate with: openssl rand -hex 32
SESSION_SECRET=

# Set to "true" to allow new account registrations. After creating your account,
# set to "false" (or remove) to close registration.
ALLOW_REGISTRATION=true

# ── Gemini (per-user) ─────────────────────────────────────────────────────────
# Each user provides their own Gemini API key via the Settings screen after login.
# You can set a fallback here for local dev convenience (single user), but this
# key is NOT used in production — users provide their own.
# GEMINI_API_KEY=

# ── Server ───────────────────────────────────────────────────────────────────
# HTTP port. Optional — defaults to 3747 locally, 8080 in Docker/Fly.
PORT=3747

# ── Google Docs/Drive (optional) ─────────────────────────────────────────────
# Only needed if you want the Google Docs/Drive fetch on artifacts / references.
# Option A (preferred for production): set individual env vars
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_TOKEN_URI=https://oauth2.googleapis.com/token
#
# Option B (local dev): point at the downloaded JSON from GCP Console
# GOOGLE_OAUTH_CLIENT_JSON=/absolute/path/to/client_secret.json
